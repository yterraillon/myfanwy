{
  "devDependencies": {
    "cross-env": "^7.0.3",
    "tailwindcss": "^3.4.1"
  },  
  "scripts": {
    "watch": "cross-env NODE_ENV=development  ./node_modules/tailwindcss/lib/cli.js -i ./Shared/Styles/input.css -o ./wwwroot/css/output.css --watch",
    "release": "cross-env NODE_ENV=production  ./node_modules/tailwindcss/lib/cli.js -i ./Shared/Styles/input.css -o ./wwwroot/css/output.css --minify"
  }
}
